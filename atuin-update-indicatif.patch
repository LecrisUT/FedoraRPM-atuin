Subject: [PATCH] Update indicatif to 0.18.0

---
 crates/atuin-client/Cargo.toml  | 2 +-
 crates/atuin-history/Cargo.toml | 2 +-
 crates/atuin/Cargo.toml         | 2 +-
 3 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/crates/atuin-client/Cargo.toml b/crates/atuin-client/Cargo.toml
index 4b9737f0..78f8a882 100644
--- a/crates/atuin-client/Cargo.toml
+++ b/crates/atuin-client/Cargo.toml
@@ -67,7 +67,7 @@ urlencoding = { version = "2.1.0", optional = true }
 reqwest = { workspace = true, optional = true }
 hex = { version = "0.4", optional = true }
 sha2 = { version = "0.10", optional = true }
-indicatif = "0.17.7"
+indicatif = ">=0.17.7, <0.19.0"
 tiny-bip39 = "2"
 
 [dev-dependencies]
diff --git a/crates/atuin-history/Cargo.toml b/crates/atuin-history/Cargo.toml
index 4437da94..54c09149 100644
--- a/crates/atuin-history/Cargo.toml
+++ b/crates/atuin-history/Cargo.toml
@@ -20,7 +20,7 @@ log = { workspace = true }
